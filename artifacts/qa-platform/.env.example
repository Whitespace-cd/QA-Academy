# Copy this to .env.local for local development
# For Vercel: add these in the Vercel dashboard under Project Settings > Environment Variables

# URL of your deployed backend API server (e.g. on Railway, Render, or Fly.io)
# Leave empty if backend is not yet deployed (features requiring login won't work)
VITE_API_URL=https://your-api-server.railway.app

# For local development this is not needed (uses /api proxy)
